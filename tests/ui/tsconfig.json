{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@fixtures/*": ["./fixtures/*"],
      "@helpers/*": ["./tests/helpers/*"]
    }
  },
  "include": [
    "fixtures/**/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts",
    "../../**/e2e/**/*.ts"
  ]
}
